# ─────────────────────────────────────────────────────────────
# WAJIB
# ─────────────────────────────────────────────────────────────

# PostgreSQL (local, Neon, Supabase, Railway, dll.)
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/jurnal_emas"

# Better Auth — generate: `openssl rand -base64 32`
BETTER_AUTH_SECRET="change-me-to-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# OPSIONAL — fitur di bawah aktif HANYA jika key diisi.
# Tanpa key, app tetap jalan (fallback aman). Lihat INTEGRATIONS_SETUP.md.
# ─────────────────────────────────────────────────────────────

# Google OAuth (tombol "Masuk dengan Google"). Kosong = tombol non-aktif.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (Resend) — verifikasi email & reset password ("Lupa sandi").
# Tanpa ini, tautan reset DICETAK ke console server (tetap bisa dites di dev).
RESEND_API_KEY=""
EMAIL_FROM="Jurnal Emas Si Kecil <no-reply@jurnalemas.com>"

# Upload gambar (Cloudinary) — foto profil, foto anak/milestone.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# AI Coach "Pendamping Emas" (Google Gemini, free tier).
# Key gratis: https://aistudio.google.com/apikey — tanpa ini /api/coach balas 503.
GEMINI_API_KEY=""
# Opsional, default "gemini-2.5-flash".
GEMINI_MODEL="gemini-2.5-flash"

# Pembayaran (Midtrans) — subscription premium nyata.
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
# Dipakai PLAN_PRICES (rupiah). Boleh dikosongkan (default 49000 / 399000).
PRICE_MONTHLY="49000"
PRICE_YEARLY="399000"

# Error monitoring (Sentry) — opsional. Kosong = nonaktif.
NEXT_PUBLIC_SENTRY_DSN=""
