# ─────────────────────────────────────────────────────────────
# WAJIB
# ─────────────────────────────────────────────────────────────

# PostgreSQL (local, Neon, Supabase, Railway, dll.)
# PRODUKSI (Vercel/serverless): WAJIB pakai connection string "pooled" (Neon
# pooler / Supabase "Transaction" port 6543 / pgBouncer) — bukan koneksi
# langsung — agar koneksi tidak habis saat ramai.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/jurnal_emas"

# Tuning pool DB (opsional, ada default aman). Di serverless biarkan kecil.
# DB_POOL_MAX default 1 di production, 10 di dev. Naikkan hanya jika pooler kuat.
# DB_POOL_MAX=1
# DB_IDLE_TIMEOUT=20      # detik, tutup koneksi nganggur
# DB_CONNECT_TIMEOUT=10   # detik, gagal cepat daripada menggantung

# Better Auth — generate: `openssl rand -base64 32`
BETTER_AUTH_SECRET="change-me-to-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Rate limit auth (anti brute-force). Default "memory" (per-instance, aman tanpa
# tabel). Setelah migrasi tabel rate_limit dijalankan, set ke "database" agar
# limit berlaku lintas instance serverless. JANGAN set "database" sebelum migrasi.
# AUTH_RATELIMIT_STORAGE=database

# ─────────────────────────────────────────────────────────────
# OPSIONAL — fitur di bawah aktif HANYA jika key diisi.
# Tanpa key, app tetap jalan (fallback aman). Lihat INTEGRATIONS_SETUP.md.
# ─────────────────────────────────────────────────────────────

# Google OAuth (tombol "Masuk dengan Google"). Kosong = tombol non-aktif.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (Resend) — verifikasi email & reset password ("Lupa sandi").
# Tanpa ini, tautan reset DICETAK ke console server (tetap bisa dites di dev).
RESEND_API_KEY=""
EMAIL_FROM="Jurnal Emas Si Kecil <no-reply@jurnalemas.com>"

# Upload gambar (Cloudinary) — foto profil, foto anak/milestone.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# AI Coach "Pendamping Emas" (Google Gemini, free tier).
# Key gratis: https://aistudio.google.com/apikey — tanpa ini /api/coach balas 503.
GEMINI_API_KEY=""
# Opsional, default "gemini-2.5-flash".
GEMINI_MODEL="gemini-2.5-flash"
# Batas pertanyaan AI per user per hari (lindungi kuota free). Default 20.
COACH_DAILY_LIMIT="20"

# Pembayaran (Midtrans) — subscription premium nyata. Kosong = mode demo (503).
# Webhook: set "Payment Notification URL" di dashboard Midtrans ke
#   https://<domain>/api/payment/notify   (Sandbox dulu untuk uji).
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
# Dipakai PLAN_PRICES (rupiah). Boleh dikosongkan (default 49000 / 399000).
PRICE_MONTHLY="49000"
PRICE_YEARLY="399000"

# Error monitoring (Sentry) — opsional. Kosong = nonaktif.
NEXT_PUBLIC_SENTRY_DSN=""
